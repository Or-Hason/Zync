# ─── Database ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=zync_user
DB_PASSWORD=zync_password
DB_NAME=zync_db

# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Ollama (local AI inference) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Model tag must exist locally (`ollama pull llama3:8b`). If you only have the
# `llama3:latest` 8B tag pulled, set OLLAMA_MODEL=llama3:latest instead.
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_SECONDS=120

# ─── Gemini (cloud AI inference for match scoring) ──────────────────────────
# Obtain a key from Google AI Studio. Required for the job match-scoring engine;
# the /api/jobs/scrape endpoint aborts with HTTP 500 when it is missing.
GEMINI_API_KEY=
# Comma-separated fallback chain. The engine rotates forward on 429 errors
# and resets to the primary model automatically after 1 hour.
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-3.5-flash,gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30

# ─── Resume uploads ─────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ─── Background scraper (JobMaster auto-scan) ───────────────────────────────
# Base site URL for the JobMaster scraper. The keyword search URL is derived
# from this at runtime using the active resume's target_role.
JOBMASTER_BASE_URL=https://www.jobmaster.co.il/
# Hard cap on jobs processed on the VERY FIRST scan for this source, so the
# initial import never burns a large batch of Gemini calls at once.
INITIAL_SCAN_LIMIT=3
# Defensive ceiling on jobs processed per scheduler tick on ANY run. Protects
# against a portal returning hundreds of new links in a single cycle.
MAX_JOBS_PER_SCAN=4
# Master switch for the background scheduler. Set to false to disable auto-scan
# entirely at the process level (overrides the per-user auto_scan_enabled flag).
SCHEDULER_ENABLED=true
