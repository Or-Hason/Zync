# ─── Database ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=zync_user
DB_PASSWORD=zync_password
DB_NAME=zync_db

# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Ollama (local AI inference) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Model tag must exist locally (`ollama pull llama3:8b`). If you only have the
# `llama3:latest` 8B tag pulled, set OLLAMA_MODEL=llama3:latest instead.
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_SECONDS=120

# ─── Gemini (cloud AI inference for match scoring) ──────────────────────────
# Obtain a key from Google AI Studio. Required for the job match-scoring engine;
# the /api/jobs/scrape endpoint aborts with HTTP 500 when it is missing.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_SECONDS=30

# ─── Resume uploads ─────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
